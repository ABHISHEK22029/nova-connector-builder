<?xml version="1.0" encoding="UTF-8"?>
<contentMapping>
    <sourceType>User</sourceType>
    <targetType>EdCastContent</targetType>
    <fieldMapping>
        <sourceField>userId</sourceField>
        <targetField>contentId</targetField>
        <defaultValue>defaultUserId</defaultValue>
    </fieldMapping>
    <fieldMapping>
        <sourceField>firstName</sourceField>
        <targetField>title</targetField>
    </fieldMapping>
    <fieldMapping>
        <sourceField>lastName</sourceField>
        <targetField>description</targetField>
    </fieldMapping>
    <fieldMapping>
        <sourceField>email</sourceField>
        <targetField>url</targetField>
    </fieldMapping>
    <fieldMapping>
        <sourceField>status</sourceField>
        <targetField>contentType</targetField>
        <defaultValue>User</defaultValue>
    </fieldMapping>
    <fieldMapping>
        <sourceField>department</sourceField>
        <targetField>tags</targetField>
    </fieldMapping>
    <fieldMapping>
        <sourceField>division</sourceField>
        <targetField>channel</targetField>
    </fieldMapping>
    <fieldMapping>
        <sourceField>location</sourceField>
        <targetField>source</targetField>
        <defaultValue>SuccessFactors</defaultValue>
    </fieldMapping>
    <fieldMapping>
        <sourceField>lastModifiedDateTime</sourceField>
        <targetField>updatedAt</targetField>
        <transformation>
            <expressionType>saba-spel</expressionType>
            <expression>T(java.time.OffsetDateTime).parse(#source).toInstant().toEpochMilli()</expression>
        </transformation>
    </fieldMapping>
    <fieldMapping>
        <sourceField>startDate</sourceField>
        <targetField>createdAt</targetField>
        <transformation>
            <expressionType>saba-spel</expressionType>
            <expression>T(java.time.OffsetDateTime).parse(#source).toInstant().toEpochMilli()</expression>
        </transformation>
    </fieldMapping>
    <acceptRecord>
        <expressionType>saba-spel</expressionType>
        <expression>#source.status == 'active'</expression>
    </acceptRecord>
</contentMapping>