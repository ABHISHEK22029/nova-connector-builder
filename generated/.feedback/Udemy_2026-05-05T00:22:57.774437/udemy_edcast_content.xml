<?xml version="1.0" encoding="UTF-8"?>
<integrationMapping>
  <mapping source="id" target="EXTERNAL_ID" required="true"/>
  <mapping source="title" target="TITLE" required="true"/>
  <mapping source="description" target="DESCRIPTION"/>
  <mapping source="url" target="LAUNCH_URL"/>
  <mapping source="image_480x270" target="IMAGE_URL"/>
  <mapping source="estimated_content_length" target="DURATION"/>
  <mapping source="title" target="PROVIDER_NAME" defaultValue="Udemy"/>
  <mapping source="_class" target="CONTENT_TYPE" defaultValue="COURSE"/>
  <mapping source="locale.title" target="LANGUAGE" defaultValue="en"/>
  <mapping source="last_modified" target="LAST_MODIFIED_DATE"/>

  <!-- Accept filter — controls which records are imported -->
  <acceptRecord>
    <filter field="is_published" value="True"/>
  </acceptRecord>
</integrationMapping>