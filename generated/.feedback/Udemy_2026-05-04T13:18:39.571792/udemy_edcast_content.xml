<?xml version="1.0" encoding="UTF-8"?>
<integrationMapping>
  <mapping source="id" target="EXTERNAL_ID" required="true"/>
  <mapping source="title" target="TITLE" required="true"/>
  <mapping source="description" target="DESCRIPTION"/>
  <mapping source="url" target="LAUNCH_URL"/>
  <mapping source="image_125_H" target="IMAGE_URL"/>
  <mapping source="estimated_content_length" target="DURATION"/>
  <mapping source="locale_id" target="LANGUAGE" defaultValue="en"/>
  <mapping source="last_update_date" target="LAST_MODIFIED_DATE"/>

  <!-- Default values for fields not directly mapped or requiring a static value -->
  <mapping target="PROVIDER_NAME" defaultValue="Udemy"/>
  <mapping target="CONTENT_TYPE" defaultValue="COURSE"/>

  <!-- Accept filter — controls which records are imported -->
  <acceptRecord>
    <filter field="is_published" value="true"/>
  </acceptRecord>
</integrationMapping>