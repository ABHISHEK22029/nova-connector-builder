# LLM Gateway (CSOD Internal)
LLM_GATEWAY_URL=https://dev01-llm-platform.itf.csodqa.com/v3/generate
LLM_GATEWAY_TOKEN=your_bearer_token_here
LLM_GATEWAY_MODEL=anthropic-sonnet-4.0

# Direct Anthropic API (fallback)
ANTHROPIC_API_KEY=

# Embedding Model
EMBEDDING_MODEL=BAAI/bge-large-en
# EMBEDDING_MODEL=all-MiniLM-L6-v2

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_db

# SIH Codebase Path (for ingestion)
SIH_CODEBASE_PATH=../

# Output directory for generated connectors
OUTPUT_DIR=./generated
